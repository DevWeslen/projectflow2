// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       String  @id @default(cuid())
  name     String
  username String  @unique
  role     String
  password String? @default("123")
  projects Project[] @relation("ProjectOwner")
}

model Project {
  id           String   @id @default(cuid())
  name         String
  description  String?
  methodology  String
  color        String
  category     String
  ownerId      String
  owner        User     @relation("ProjectOwner", fields: [ownerId], references: [id])
  memberIds    String   // JSON array of strings
  stakeholderIds String? // JSON array of strings
  externalStakeholderNames String?
  attachments  String?   // JSON array of attachment objects
  generalKpis  String   // JSON array of KPI objects
  yearlyGoals  String   // JSON array of YearlyGoal objects
  deadline     DateTime?
  actualStartDate DateTime?
  actualEndDate   DateTime?
  sprintDuration Int?
  totalSprints  Int?
  status        String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tasks        Task[]
  riskAnalyses RiskAnalysis[]
}

model TaskDependency {
  id            String   @id @default(cuid())
  predecessorId String
  predecessor   Task     @relation("SuccessorDependencies", fields: [predecessorId], references: [id], onDelete: Cascade)
  successorId   String
  successor     Task     @relation("PredecessorDependencies", fields: [successorId], references: [id], onDelete: Cascade)
  type          String   @default("finish_to_start")
  createdAt     DateTime @default(now())

  @@unique([predecessorId, successorId])
}

model Task {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId    String?
  ownerId     String?
  stakeholderIds String? // JSON array of strings
  externalStakeholderNames String?
  externalOwnerName String?
  attachments String?   // JSON array of attachment objects
  title       String
  description String?
  status      String
  progress    Float
  order       Int
  deadline    DateTime?
  actualStartDate DateTime?
  actualEndDate   DateTime?
  sprint      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  predecessors TaskDependency[] @relation("PredecessorDependencies")
  successors   TaskDependency[] @relation("SuccessorDependencies")
}

model RiskAnalysis {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String
  title     String
  data      String   // JSON object
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
